---

---

<section
  class="flex flex-col justify-center items-center gap-10 min-h-[85vh] p-8 text-center w-full"
>
  <!-- Greeting (animated) -->
  <p class="text-[var(--color-subtext)] text-2xl font-medium tracking-wide">
    <span id="greeting-text"></span><span
      id="greeting-cursor"
      class="greeting-cursor">|</span
    >
  </p>

  <!-- Headline -->
  <h1
    class="text-[var(--color-text)] text-7xl md:text-8xl font-extrabold leading-tight tracking-tight"
  >
    I build fronts<br />and backs.
  </h1>

  <!-- CTA -->
  <a
    href="#experience"
    class="inline-flex items-center gap-3 px-7 py-4 rounded-full border border-[var(--color-borderhover)] text-[var(--color-text)] text-base font-semibold hover:bg-[var(--color-middleground)] hover:border-[var(--color-buttonhover)] transition-colors"
  >
    See my experience
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <line x1="5" y1="12" x2="19" y2="12"></line>
      <polyline points="12 5 19 12 12 19"></polyline>
    </svg>
  </a>
</section>

<style>
  .greeting-cursor {
    animation: blink 1s step-end infinite;
  }
  .greeting-cursor.done {
    animation: none;
    opacity: 0;
  }
  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
</style>

<script>
  const el = document.getElementById("greeting-text")!;
  const cursor = document.getElementById("greeting-cursor")!;

  const sleep = (ms: number) => new Promise<void>((r) => setTimeout(r, ms));

  async function type(text: string, speed = 80) {
    for (const char of text) {
      el.textContent += char;
      await sleep(speed);
    }
  }

  async function erase(count: number, speed = 50) {
    for (let i = 0; i < count; i++) {
      el.textContent = el.textContent!.slice(0, -1);
      await sleep(speed);
    }
  }

  async function run() {
    await type("Good... ");
    await sleep(500);

    // morning?
    await type("morning?");
    await sleep(1400);
    await erase("morning?".length);
    await sleep(300);

    // afternoon?
    await type("afternoon?");
    await sleep(1400);
    await erase("afternoon?".length);
    await sleep(300);

    // night?
    await type("night?");
    await sleep(1400);

    // delete everything
    await erase(el.textContent!.length, 40);
    await sleep(400);

    // final: Hello,
    await type("Hello,");

    // stop the cursor blink
    cursor.classList.add("done");
  }

  run();
</script>
