---
const projects = [
  {
    name: "Escapada",
    description: "Real-time collaborative packing list for group trips, with live sync and shared checklists built on Firebase",
    tags: ["React", "Firebase", "Tailwind", "Vite"],
    image: "/projects/escapada.png",
    previewUrl: "https://escapada-jet.vercel.app",
    githubUrl: "https://github.com/AntonioMangado/escapada",
  },
  {
    name: "Imagena",
    description: "Photo discovery app that lets you browse and save favourites from thousands of images via the Unsplash API",
    tags: ["React", "Unsplash API", "SCSS"],
    image: "/projects/imagena.png",
    previewUrl: "https://imagena-manager.netlify.app/",
    githubUrl: "https://github.com/AntonioMangado/Imagena",
  },
  {
    name: "Monster Hunter Companion",
    description: "Tool that calculates and returns the most optimal weapon for any monster hunt in Monster Hunter World",
    tags: ["JavaScript", "HTML", "CSS"],
    image: "/projects/mh-companion.png",
    previewUrl: "https://antoniomangado.github.io/monterHunterCompanion/",
    githubUrl: "https://github.com/AntonioMangado/monterHunterCompanion",
  },
  {
    name: "Unit Converter",
    description: "Multi-category unit conversion app built to explore and practice Redux state management patterns",
    tags: ["React", "Redux", "SCSS"],
    image: "/projects/unit-converter.png",
    previewUrl: "https://antonios-unit-converter.netlify.app/",
    githubUrl: "https://github.com/AntonioMangado/UnitConverter",
  },
  {
    name: "RGM Landing",
    description: "Marketing landing page for RGM consultancy, focused on performance and clean responsive design",
    tags: ["Astro", "CSS"],
    image: "/projects/rgm-landing.png",
    previewUrl: "https://rgm-landing.vercel.app",
    githubUrl: "https://github.com/AntonioMangado/rgm-landing",
  },
];
---

<section
  id="projects"
  class="flex flex-col items-center w-full px-8 pb-24 scroll-mt-32"
>
  <div class="max-w-6xl mx-auto w-full flex flex-col gap-6">
    <!-- Section heading -->
    <div class="reveal mb-4 flex flex-col items-center">
      <div class="flex items-center gap-3">
        <h2 class="text-[var(--color-text)] text-4xl font-extrabold">
          Projects
        </h2>
        <span class="rounded-full border border-[var(--color-borderhover)] bg-[var(--color-middleground)] text-[var(--color-subtext)] text-xs px-3 py-1">
          {projects.length}
        </span>
      </div>
      <div class="proj-divider mt-3"></div>
    </div>

    <!-- Card grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project, i) => (
        <div
          class="reveal proj-card rounded-2xl border border-[var(--color-borderhover)] bg-[var(--color-middleground)] overflow-hidden flex flex-col hover:-translate-y-1 transition-transform"
          style={`transition-delay: ${i * 0.08}s`}
        >
          <!-- Preview area -->
          <div class="relative h-56 overflow-hidden">
            <img
              src={project.image}
              alt={project.name}
              class="absolute inset-0 w-full h-full object-cover object-top"
              loading="lazy"
              decoding="async"
            />
            <!-- Action buttons -->
            <div class="absolute top-2 right-2 flex gap-1.5 z-10">
              {project.previewUrl && (
                <a
                  href={project.previewUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Visit live site"
                  class="proj-source-btn w-8 h-8 flex items-center justify-center rounded-lg border border-[var(--color-borderhover)] bg-[var(--color-middleground)] text-[var(--color-subtext)] transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                    <polyline points="15 3 21 3 21 9"/>
                    <line x1="10" y1="14" x2="21" y2="3"/>
                  </svg>
                </a>
              )}
              <a
                href={project.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="View source on GitHub"
                class="proj-source-btn w-8 h-8 flex items-center justify-center rounded-lg border border-[var(--color-borderhover)] bg-[var(--color-middleground)] text-[var(--color-subtext)] transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Card body -->
          <div class="px-5 py-4 flex flex-col gap-1">
            <span class="font-extrabold text-[var(--color-text)] text-base">
              {project.name}
            </span>
            <p class="text-sm text-[var(--color-subtext)] line-clamp-1">
              {project.description}
            </p>
            <!-- Tech tags -->
            <div class="flex flex-wrap gap-1.5 mt-2">
              {project.tags.map((tag) => (
                <span class="rounded-full bg-[var(--color-foreground)] border border-[var(--color-borderhover)] text-[var(--color-subtext)] text-xs px-3 py-0.5">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>


<style>
  .proj-divider {
    width: 4rem;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(98, 114, 255, 0.55),
      transparent
    );
  }

  .proj-card {
    box-shadow: 0 0 30px 0 rgba(98, 114, 255, 0.05);
  }

  .proj-card:hover {
    border-color: var(--color-buttonhover);
  }

  .proj-source-btn:hover {
    color: var(--color-text);
    border-color: var(--color-buttonhover);
  }
</style>
