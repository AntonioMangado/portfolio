---

---

<nav
  id="navbar"
  class="sticky top-0 z-50 w-full bg-[var(--color-background)] transition-transform duration-300"
>
  <div class="max-w-6xl mx-auto w-full flex items-center p-8">
    <!-- Left: avatar + identity -->
    <div class="flex flex-1 items-center justify-start gap-3">
      <img
        src="/pp.png"
        alt="Antonio Mangado"
        class="w-14 h-14 rounded-full object-cover border border-[var(--color-borderhover)] flex-shrink-0"
      />
      <div>
        <p
          class="font-extrabold font text-[var(--color-text)] text-xl leading-tight tracking-tight"
        >
          Antonio Mangado
        </p>
        <p class="text-lg text-[var(--color-subtext)] leading-tight">
          fullstack developer
        </p>
      </div>
    </div>

    <!-- Center: pill nav links (desktop) -->
    <div class="flex flex-1 justify-center">
      <div
        class="hidden md:flex items-center gap-1 bg-[var(--color-middleground)] rounded-full px-2 py-1"
      >
        <a
          href="#experience"
          class="px-5 py-2 text-base font-semibold text-[var(--color-text)] rounded-full hover:bg-[var(--color-foreground)] transition-colors"
          >Experience</a
        >
        <a
          href="#projects"
          class="px-5 py-2 text-base font-semibold text-[var(--color-text)] rounded-full hover:bg-[var(--color-foreground)] transition-colors"
          >Projects</a
        >
      </div>
    </div>

    <!-- Right: social icons + mobile hamburger -->
    <div class="flex flex-1 items-center justify-end gap-2">
      <!-- GitHub -->
      <a
        href="https://github.com/AntonioMangado"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="w-11 h-11 flex items-center justify-center text-[var(--color-text)] hover:text-[var(--color-subtext)] transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="100%"
          height="100%"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
      </a>

      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/in/antonio-mangado/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="w-11 h-11 flex items-center justify-center text-[var(--color-text)] hover:text-[var(--color-subtext)] transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="100%"
          height="100%"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path>
        </svg>
      </a>

      <!-- CV Download -->
      <a
        href="/Antonio Mangado - Resume.pdf"
        download
        aria-label="Download CV"
        class="w-11 h-11 flex items-center justify-center rounded bg-[var(--color-text)] text-[var(--color-background)] hover:opacity-80 transition-opacity font-extrabold tracking-wide" style="font-size: 1.6rem;"
      >
        CV
      </a>

      <!-- Mobile hamburger -->
      <button
        id="hamburger"
        aria-label="Open menu"
        aria-expanded="false"
        class="md:hidden w-9 h-9 rounded-lg border border-[var(--color-borderhover)] flex items-center justify-center text-[var(--color-text)] hover:border-[var(--color-buttonhover)] transition-colors ml-1"
      >
        <svg
          id="hamburger-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg
          id="close-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="hidden"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-[var(--color-borderhover)] px-6 py-4 flex flex-col gap-1"
  >
    <a
      href="#experience"
      class="px-4 py-2 text-base font-semibold text-[var(--color-subtext)] rounded-lg hover:text-[var(--color-text)] hover:bg-[var(--color-middleground)] transition-colors"
      >Experience</a
    >
    <a
      href="#projects"
      class="px-4 py-2 text-base font-semibold text-[var(--color-subtext)] rounded-lg hover:text-[var(--color-text)] hover:bg-[var(--color-middleground)] transition-colors"
      >Projects</a
    >
    <a
  </div>
</nav>

<script>
  const navbar = document.getElementById("navbar");
  const mobile = () => window.matchMedia("(max-width: 767px)").matches;
  let lastScrollY = window.scrollY;

  window.addEventListener("scroll", () => {
    if (!mobile()) {
      navbar?.style.setProperty("transform", "");
      return;
    }
    const currentScrollY = window.scrollY;
    if (currentScrollY > lastScrollY && currentScrollY > 60) {
      navbar?.style.setProperty("transform", "translateY(-100%)");
    } else {
      navbar?.style.setProperty("transform", "");
    }
    lastScrollY = currentScrollY;
  }, { passive: true });

  const hamburger = document.getElementById("hamburger");
  const mobileMenu = document.getElementById("mobile-menu");
  const hamburgerIcon = document.getElementById("hamburger-icon");
  const closeIcon = document.getElementById("close-icon");

  hamburger?.addEventListener("click", () => {
    const isOpen = !mobileMenu?.classList.contains("hidden");
    mobileMenu?.classList.toggle("hidden", isOpen);
    hamburgerIcon?.classList.toggle("hidden", !isOpen);
    closeIcon?.classList.toggle("hidden", isOpen);
    hamburger.setAttribute("aria-expanded", String(!isOpen));
  });

  // Close mobile menu when a link is clicked
  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu.classList.add("hidden");
      hamburgerIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
      hamburger?.setAttribute("aria-expanded", "false");
    });
  });
</script>
